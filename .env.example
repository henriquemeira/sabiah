# Telegram Bot
TELEGRAM_BOT_TOKEN=seu_token_aqui

# Google Gemini API
GEMINI_API_KEY=sua_chave_api_aqui

# Groq API (alternativa gratuita ao Gemini)
# Obtain free API key at: https://console.groq.com/keys
GROQ_API_KEY=sua_chave_groq_aqui
# Modelo (opcional): llama-3.1-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama-3.1-70b-versatile

# Banco de Dados SQLite
DATABASE_PATH=data/sabiah.db

# ChromaDB
CHROMA_PERSIST_DIRECTORY=data/chroma_db

# Freshdesk (Futuro)
FRESHDESK_API_KEY=sua_chave_freshdesk
FRESHDESK_SUBDOMAIN=subdomain
